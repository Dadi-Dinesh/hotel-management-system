# ══════════════════════════════════════════════════════════
# SERVER ENVIRONMENT VARIABLES — for Render.com
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in values for local dev.
# On Render, set these in: Dashboard → Service → Environment

# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL="postgresql://..."

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET="your-super-secure-jwt-secret"

# ─── Server Port ─────────────────────────────────────────
PORT=4000

# ─── Cloudinary (Image Uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── CORS / Client URL ───────────────────────────────────
# LOCAL: CLIENT_URL="http://localhost:3000"
# RENDER PRODUCTION: Must be set to your Vercel frontend URL
CLIENT_URL="https://hotel-management-system-psi-kohl.vercel.app"
