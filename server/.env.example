# ══════════════════════════════════════════════════════════
# SERVER ENVIRONMENT VARIABLES — for Render.com
# ══════════════════════════════════════════════════════════
# On Render, set these in: Dashboard → Service → Environment
# Do NOT commit your actual .env to git.

# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET="your-super-secure-jwt-secret-min-32-chars"

# ─── Server Port ─────────────────────────────────────────
# Render injects this automatically — do not hardcode.
# 8080 is the safe local fallback (matches server.js default).
PORT=8080

# ─── Cloudinary (Image Uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── CORS: Allowed Frontend Origin ───────────────────────
# Set this on Render to your Vercel frontend URL.
# For multiple origins, separate with commas:
#   CLIENT_URL="https://your-app.vercel.app,https://custom-domain.com"
#
# Even if this is missing, server.js has a hard-coded safety net
# for hotel-management-system-psi-kohl.vercel.app
CLIENT_URL="https://hotel-management-system-psi-kohl.vercel.app"
