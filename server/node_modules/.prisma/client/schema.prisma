generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  ADMIN
  CAPTAIN
}

enum SessionStatus {
  ACTIVE
  BILL_REQUESTED
  CLOSED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  SERVED
  CANCELLED
}

enum BillRequestStatus {
  PENDING
  ACCEPTED
  PRINTED
}

// ─── Models ──────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CAPTAIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bills     Bill[]
}

model Table {
  id           String        @id @default(cuid())
  code         String        @unique // T01, T02, ... T12
  number       Int           @unique // 1–12
  isActive     Boolean       @default(true)
  occupied     Boolean       @default(false)
  releasedTime DateTime?
  sessions     Session[]
  billRequests BillRequest[]
}

model Session {
  id           String        @id @default(cuid())
  tableId      String
  table        Table         @relation(fields: [tableId], references: [id])
  status       SessionStatus @default(ACTIVE)
  orders       Order[]
  createdAt    DateTime      @default(now())
  closedAt     DateTime?
  billRequests BillRequest[]
  bill         Bill?
}

model Category {
  id    String     @id @default(cuid())
  name  String     @unique
  items MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  price       Float
  image       String?
  isAvailable Boolean      @default(true)
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  ratings     ItemRating[]
  createdAt   DateTime     @default(now())
}

model Order {
  id           String         @id @default(cuid())
  orderNumber  Int            @default(autoincrement())
  sessionId    String
  session      Session        @relation(fields: [sessionId], references: [id])
  status       OrderStatus    @default(PENDING)
  items        OrderItem[]
  ratings      ItemRating[]
  feedback     OrderFeedback?
  createdAt    DateTime       @default(now())
  acceptedAt   DateTime?
  billRequests BillRequest[]
  bills        Bill[]

  @@unique([orderNumber])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float // price snapshot at time of ordering
}

model ItemRating {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  rating     Int // 1 to 5
  feedback   String? // subjective feedback
  customerId String? // optional customer reference
  createdAt  DateTime @default(now())

  @@unique([orderId, menuItemId])
}

model OrderFeedback {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  overallFeedback String?
  customerId      String?
  createdAt       DateTime @default(now())
}

model BillRequest {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id])
  tableId     String
  table       Table             @relation(fields: [tableId], references: [id])
  requestTime DateTime          @default(now())
  status      BillRequestStatus @default(PENDING)
  sessionId   String
  session     Session           @relation(fields: [sessionId], references: [id])
}

model Bill {
  id            String   @id @default(cuid())
  billNumber    String   @unique
  printedTime   DateTime @default(now())
  printedById   String
  printedBy     User     @relation(fields: [printedById], references: [id])
  totalAmount   Float
  paymentStatus String   @default("PENDING") // PENDING, PAID
  printStatus   String   @default("PRINTED") // PRINTED
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  sessionId     String?  @unique
  session       Session? @relation(fields: [sessionId], references: [id])
}
