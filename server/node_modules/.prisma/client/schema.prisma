generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  ADMIN
  CAPTAIN
}

enum SessionStatus {
  ACTIVE
  BILL_REQUESTED
  CLOSED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  SERVED
  CANCELLED
}

// ─── Models ──────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CAPTAIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id       String    @id @default(cuid())
  code     String    @unique // T01, T02, ... T12
  number   Int       @unique // 1–12
  isActive Boolean   @default(true)
  sessions Session[]
}

model Session {
  id        String        @id @default(cuid())
  tableId   String
  table     Table         @relation(fields: [tableId], references: [id])
  status    SessionStatus @default(ACTIVE)
  orders    Order[]
  feedbacks Feedback[]
  createdAt DateTime      @default(now())
  closedAt  DateTime?
}

model Category {
  id    String     @id @default(cuid())
  name  String     @unique
  items MenuItem[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  price       Float
  image       String?
  isAvailable Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  feedbacks   Feedback[]
  createdAt   DateTime    @default(now())
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @default(autoincrement())
  sessionId   String
  session     Session     @relation(fields: [sessionId], references: [id])
  status      OrderStatus @default(PENDING)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  acceptedAt  DateTime?

  @@unique([orderNumber])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float // price snapshot at time of ordering
}

model Feedback {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  rating     Int
  createdAt  DateTime @default(now())
}
